# ─────────────────────────────────────────────────────────────────
#  Axilog NetTopoSuite — Environment Variables
#  Copy to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3001

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=topology
MYSQL_USER=topology_user
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=rootpass_CHANGE_ME

# ── JWT (RS256) ───────────────────────────────────────────────────
# Generate: openssl genrsa -out certs/jwt.key 4096
#           openssl rsa -in certs/jwt.key -pubout -out certs/jwt.key.pub
JWT_PRIVATE_KEY_PATH=./certs/jwt.key
JWT_PUBLIC_KEY_PATH=./certs/jwt.key.pub
JWT_EXPIRES_IN=8h

# ── Keycloak SSO (optional — set KEYCLOAK_ENABLED=true to activate) ──
KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/axilog
KEYCLOAK_CLIENT_ID=axilog-backend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KC_ADMIN_PASSWORD=CHANGE_ME

# ── Local auth ───────────────────────────────────────────────────
ALLOW_REGISTRATION=true
REQUIRE_INVITE_TOKEN=false
# SMTP for password reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@axilog.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="Axilog NetTopoSuite <noreply@axilog.com>"

# ── SNMP Trap listener ───────────────────────────────────────────
SNMP_TRAP_PORT=162
SNMP_COMMUNITY=public

# ── MCP Server ───────────────────────────────────────────────────
MCP_TRANSPORT=sse
MCP_SSE_PORT=3002

# ── Frontend (Vite build-time vars) ─────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001
VITE_MCP_URL=http://localhost:3002
VITE_KEYCLOAK_ENABLED=false
VITE_ALLOW_REGISTRATION=true
